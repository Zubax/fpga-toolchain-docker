#!/usr/bin/env bash
# Run AMD/Xilinx tools with the container-local Vivado environment.

set -euo pipefail

export XILINX_VIVADO="${XILINX_VIVADO:-/opt/Xilinx/2025.2.1/Vivado}"
compat_lib="${XILINX_VIVADO}/lib/lnx64.o/Ubuntu/24"

if [[ ! -d "${XILINX_VIVADO}" ]]; then
    echo "XILINX_VIVADO does not exist: ${XILINX_VIVADO}" >&2
    exit 127
fi

export PATH="${XILINX_VIVADO}/bin:${PATH}"
if [[ -d "${compat_lib}" ]]; then
    export LD_LIBRARY_PATH="${compat_lib}${LD_LIBRARY_PATH:+:${LD_LIBRARY_PATH}}"
fi

tool="$(basename "$0")"
if [[ "${tool}" == "amd-tool" || "${tool}" == "vivado-env" ]]; then
    if (($# > 0)); then
        exec "$@"
    fi
    exec /bin/bash
fi

if [[ "${tool}" == "vivado" ]]; then
    for candidate in /usr/lib/x86_64-linux-gnu/libudev.so.1 /lib/x86_64-linux-gnu/libudev.so.1; do
        if [[ -e "${candidate}" ]]; then
            case ":${LD_PRELOAD:-}:" in
                *":${candidate}:"*) ;;
                *) export LD_PRELOAD="${candidate}${LD_PRELOAD:+:${LD_PRELOAD}}" ;;
            esac
            break
        fi
    done

    args=("$@")
    for i in "${!args[@]}"; do
        if [[ "${args[$i]}" == "-source" || "${args[$i]}" == "-script" ]]; then
            script_index=$((i + 1))
            if ((script_index >= ${#args[@]})); then
                break
            fi
            script="${args[$script_index]}"
            script="${script//\\/\\\\}"
            script="${script//\"/\\\"}"
            script="${script//\$/\\$}"
            script="${script//[/\\[}"
            wrapper="$(mktemp "${TMPDIR:-/tmp}/vivado-wrapper.XXXXXX.tcl")"
            trap 'rm -f "${wrapper}"' EXIT
            {
                printf '%s\n' 'catch {config_webtalk -user off}'
                printf '%s\n' 'catch {config_webtalk -install off}'
                printf 'source "%s"\n' "${script}"
            } >"${wrapper}"
            args[$script_index]="${wrapper}"
            "${XILINX_VIVADO}/bin/${tool}" "${args[@]}"
            exit $?
        fi
    done
fi

exec "${XILINX_VIVADO}/bin/${tool}" "$@"
